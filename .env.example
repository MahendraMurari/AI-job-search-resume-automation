# Job search configuration
JOB_SEARCH_QUERY="AI ML Engineer OR Machine Learning Engineer OR Generative AI Engineer"
JOB_LOCATION="United States"
MAX_JOBS_TO_PROCESS=20
APIFY_RESULT_COUNT=40

# Apify
APIFY_ACTOR_ID="your_apify_actor_id"
APIFY_TOKEN="your_apify_token"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"

# Google Docs / Drive
GOOGLE_DOC_RESUME_ID="your_google_doc_resume_id"
GOOGLE_DRIVE_FOLDER_ID="your_google_drive_folder_id"

# Email
EMAIL_TO="your_email@example.com"

# Candidate placeholders
CANDIDATE_NAME="Candidate Name"
CANDIDATE_LOCATION="City, State"
CANDIDATE_PHONE="+1-000-000-0000"
CANDIDATE_EMAIL="candidate@example.com"
CANDIDATE_LINKEDIN="https://www.linkedin.com/in/example"

# LLM
LLM_PROVIDER="gemini"
GEMINI_MODEL="models/gemini-2.5-flash-lite"
GEMINI_API_KEY="your_gemini_api_key"
